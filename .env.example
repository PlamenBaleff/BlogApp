# Database
DATABASE_URL=postgresql://user:password@region.neon.tech/database?sslmode=require

# Authentication
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000

# Expo/Mobile
NEXT_PUBLIC_MOBILE_API_URL=http://localhost:3000

# Cloudflare R2 (object storage for post cover images)
# Create a bucket in the Cloudflare dashboard, then issue an R2 API token
# with read+write access to that bucket. R2_PUBLIC_BASE_URL is the public
# hostname mapped to the bucket (custom domain or `*.r2.dev` URL).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<32-hex-character-R2-access-key>
R2_SECRET_ACCESS_KEY=<64-hex-character-R2-secret>
R2_BUCKET=bloghub-uploads
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
